#!/usr/bin/env python3
import subprocess
import argparse
import sys
import time
import datetime
import os
import fcntl
import re

# --- Helpers ---

def parse_duration(val):
    if not val or val == "-": return 0
    val = str(val).lower().strip()
    if val.isdigit(): return int(val) * 60
    try:
        unit = val[-1]
        num = float(val[:-1])
        if unit == 'm': return int(num * 60)
        if unit == 'h': return int(num * 3600)
        if unit == 'd': return int(num * 86400)
    except: return 0
    return 0

def human_duration(seconds):
    if seconds <= 0: return "0s"
    if seconds >= 86400 and seconds % 86400 == 0: return f"{int(seconds // 86400)}d"
    if seconds >= 3600 and seconds % 3600 == 0: return f"{int(seconds // 3600)}h"
    if seconds >= 60 and seconds % 60 == 0: return f"{int(seconds // 60)}m"
    if seconds >= 86400: return f"{round(seconds / 86400, 2)}d"
    if seconds >= 3600: return f"{round(seconds / 3600, 2)}h"
    return f"{int(seconds // 60)}m"

def get_pv():
    path = subprocess.run(["which", "pv"], capture_output=True, text=True).stdout.strip()
    return path if path and os.path.exists(path) else None

# --- Core Logic ---

class ZzDataset:
    def __init__(self, name):
        self.name = name
        self.props = self._get_props()

    def _get_props(self):
        try:
            subprocess.check_call(["zfs", "list", self.name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            cmd = ["zfs", "get", "all", "-H", "-o", "property,value", self.name]
            res = subprocess.check_output(cmd, encoding='utf-8')
            return {p: v for p, v in (line.split('\t') for line in res.strip().split('\n')) if p.startswith("zz:")}
        except: return None

    @property
    def target(self): return self.props.get("zz:target", "-")
    
    @property
    def last_sync(self):
        val = self.props.get("zz:last_sync", "0")
        return int(val) if val.isdigit() else 0

    def set_prop(self, prop, value):
        subprocess.run(["zfs", "set", f"zz:{prop}={value}", self.name], check=True)

def get_managed_datasets():
    try:
        cmd = ["zfs", "get", "-H", "-t", "filesystem", "-s", "local", "-o", "name", "zz:target"]
        res = subprocess.check_output(cmd, encoding='utf-8')
        return [line.strip() for line in res.strip().split('\n') if line.strip() and line.strip() != "NAME"]
    except: return []

# --- Actions ---

def get_token(host, dataset):
    try:
        cmd = ["ssh", "-o", "BatchMode=yes", host, f"zfs get -H -o value receive_resume_token {dataset}"]
        res = subprocess.check_output(cmd, encoding='utf-8', stderr=subprocess.DEVNULL)
        return res.strip()
    except:
        return "-"

def is_token_active(host, dataset):
    t1 = get_token(host, dataset)
    if t1 == "-": return False
    time.sleep(3)
    t2 = get_token(host, dataset)
    return t1 != t2

def is_busy_local(dataset):
    """Local process check without the 'stray backslash' warning."""
    # We use the raw dataset name. grep -E handles slashes fine without escapes.
    check_cmd = f"ps -Aww -o args | grep -E 'zfs .*(send|recv|receive).* {dataset}(@| |$)' | grep -v grep"
    return subprocess.run(check_cmd, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0

def run_transfer(send_cmd, recv_cmd):
    sys.stdout.flush()
    pv_path = get_pv()
    if pv_path:
        send_proc = subprocess.Popen(send_cmd, stdout=subprocess.PIPE)
        pv_proc = subprocess.Popen([pv_path, "-pterb"], stdin=send_proc.stdout, stdout=subprocess.PIPE)
        recv_proc = subprocess.Popen(recv_cmd, stdin=pv_proc.stdout)
        send_proc.stdout.close()
        pv_proc.stdout.close()
        recv_proc.communicate()
        return recv_proc.returncode
    else:
        send_proc = subprocess.Popen(send_cmd, stdout=subprocess.PIPE)
        recv_proc = subprocess.Popen(recv_cmd, stdin=send_proc.stdout)
        send_proc.stdout.close()
        recv_proc.communicate()
        return recv_proc.returncode

def run_prune(ds, remote_host=None):
    is_remote = remote_host is not None
    prop_name = "zz:keep_remote" if is_remote else "zz:keep_local"
    retention_sec = parse_duration(ds.props.get(prop_name, "7d"))
    keep_min = int(ds.props.get("zz:keep_min", "10"))
    label = f"remote ({remote_host})" if is_remote else "local"
    print(f"    [*] Pruning {label}...", flush=True)
    
    cmd = ["zfs", "list", "-t", "snapshot", "-H", "-o", "name,creation", "-p", "-S", "creation", ds.name]
    if is_remote: cmd = ["ssh", "-o", "BatchMode=yes", remote_host] + cmd
    
    try:
        res = subprocess.check_output(cmd, encoding='utf-8', stderr=subprocess.DEVNULL)
        snapshots = [(l.split('\t')[0], int(l.split('\t')[1])) for l in res.strip().split('\n') if "@zz_auto_" in l]
        if len(snapshots) <= keep_min: return
        now = int(time.time())
        to_delete = [s[0] for s in snapshots[keep_min:] if (now - s[1]) > retention_sec]
        for snap in to_delete:
            print(f"        [-] Destroying {snap}", flush=True)
            del_cmd = ["zfs", "destroy", "-r", snap]
            if is_remote: del_cmd = ["ssh", remote_host] + del_cmd
            subprocess.run(del_cmd, check=True)
    except: pass

def run_init(args):
    ds = ZzDataset(args.dataset)
    if not ds or ds.props is None:
        print(f"[!] Error: Dataset '{args.dataset}' not found.", flush=True); return
    
    remote_host, remote_path = args.remote.split(':')
    remote_pool = remote_path.split('/')[0]
    
    if is_busy_local(args.dataset) or is_token_active(remote_host, args.dataset):
        print(f"[*] {args.dataset}: Transfer already active. Skipping.", flush=True); return

    token = get_token(remote_host, args.dataset)
    if token != "-":
        print(f"[*] Resuming initial sync...", flush=True)
        send_cmd = ["zfs", "send", "-v", "-t", token]
        recv_cmd = ["ssh", remote_host, f"zfs recv -s -du {remote_pool}"]
        if run_transfer(send_cmd, recv_cmd) == 0:
            ds.set_prop("target", args.remote); ds.set_prop("freq", args.freq); ds.set_prop("last_sync", int(time.time()))
            print("[+] Resume successful. Init complete.", flush=True)
        return

    ds.set_prop("target", args.remote); ds.set_prop("freq", args.freq)
    ds.set_prop("keep_local", args.keep_local); ds.set_prop("keep_remote", args.keep_remote); ds.set_prop("keep_min", args.keep_min)
    snap = f"zz_auto_{int(time.time())}"
    print(f"[*] Creating initial snapshot: {args.dataset}@{snap}", flush=True)
    subprocess.run(["zfs", "snapshot", "-r", f"{args.dataset}@{snap}"], check=True)
    
    print(f"[*] Starting initial transfer (Resumable)...", flush=True)
    send_cmd = ["zfs", "send", "-R", "-v", f"{args.dataset}@{snap}"]
    recv_cmd = ["ssh", remote_host, f"zfs recv -s -du {remote_pool}"]
    if run_transfer(send_cmd, recv_cmd) == 0:
        ds.set_prop("last_sync", int(time.time())); print("[+] Init successful.", flush=True)
    else: print("[!] Transfer interrupted. Run again to resume.", flush=True)

def run_sync(args):
    names = [args.dataset] if args.dataset else get_managed_datasets()
    for name in names:
        ds = ZzDataset(name)
        if not ds or not ds.props or ds.target == "-": continue
        
        remote_host, remote_path = ds.target.split(':')
        remote_pool = remote_path.split('/')[0]

        if is_busy_local(name):
            print(f"[*] {name}: Active ZFS process detected locally. Skipping.", flush=True); continue
        
        if is_token_active(remote_host, name):
            print(f"[*] {name}: Active remote sync detected (Token growth). Skipping.", flush=True); continue

        lock_path = f"/tmp/zz_{name.replace('/', '_')}.lock"
        lock_f = open(lock_path, 'w')
        try: 
            fcntl.flock(lock_f, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except IOError:
            print(f"[*] {name}: Local file lock held. Skipping.", flush=True)
            lock_f.close(); continue 

        token = get_token(remote_host, name)
        if token != "-":
            if is_token_active(remote_host, name):
                lock_f.close(); continue
            print(f"[*] {name}: Resuming interrupted transfer...", flush=True)
            send_cmd = ["zfs", "send", "-v", "-t", token]
            recv_cmd = ["ssh", remote_host, f"zfs recv -s -du {remote_pool}"]
            if run_transfer(send_cmd, recv_cmd) != 0:
                lock_f.close(); continue

        now_ts = int(time.time()); freq_sec = parse_duration(ds.props.get("zz:freq", "60m"))
        if ds.last_sync > 0 and not args.force:
            if (now_ts - ds.last_sync) < 60: lock_f.close(); continue
            if (now_ts - ds.last_sync) < (freq_sec - 5): lock_f.close(); continue

        print(f"[*] Processing {ds.name}...", flush=True)
        time.sleep(1.2)
        new_snap_tag = f"zz_auto_{int(time.time())}"
        subprocess.run(["zfs", "snapshot", "-r", f"{ds.name}@{new_snap_tag}"], check=True)

        try:
            cmd = ["ssh", "-o", "BatchMode=yes", remote_host, f"zfs list -t snapshot -H -S creation -o name {ds.name}"]
            res = subprocess.check_output(cmd, encoding='utf-8')
            remote_snaps = [l.strip().split('@')[1] for l in res.strip().split('\n') if "@zz_auto_" in l]
            bridge = remote_snaps[0]
        except: lock_f.close(); continue

        cmd = ["zfs", "list", "-t", "snapshot", "-H", "-o", "name", "-s", "creation", ds.name]
        local_list = subprocess.check_output(cmd, encoding='utf-8').strip().split('\n')
        pending = []
        found_bridge = False
        for s in local_list:
            tag = s.split('@')[1] if '@' in s else ""
            if tag == bridge: found_bridge = True; continue
            if found_bridge and "@zz_auto_" in s: pending.append(tag)

        current_base = bridge
        success = True
        for next_tag in pending:
            print(f"    [*] Sending @{current_base} -> @{next_tag}", flush=True)
            send_cmd = ["zfs", "send", "-R", "-v", "-i", f"@{current_base}", f"{ds.name}@{next_tag}"]
            recv_cmd = ["ssh", remote_host, f"zfs recv -s -du {remote_pool}"]
            if run_transfer(send_cmd, recv_cmd) != 0:
                success = False; break
            current_base = next_tag

        if success:
            ds.set_prop("last_sync", int(time.time()))
            run_prune(ds); run_prune(ds, remote_host)
        
        fcntl.flock(lock_f, fcntl.LOCK_UN); lock_f.close()

def run_forget(args):
    ds = ZzDataset(args.dataset)
    if not ds or not ds.props: return
    for prop in list(ds.props.keys()): subprocess.run(["zfs", "inherit", prop, ds.name])

def run_restore(args):
    remote_host, remote_ds = args.remote.split(':')
    local_ds = args.local_dataset
    local_pool = local_ds.split('/')[0]
    print(f"[*] Starting Recovery: {args.remote} -> {local_ds}", flush=True)
    try:
        cmd = ["ssh", "-o", "BatchMode=yes", remote_host, f"zfs list -t snapshot -H -S creation -o name {remote_ds} && zfs get all -H -o property,value {remote_ds}"]
        res = subprocess.check_output(cmd, encoding='utf-8')
        lines = res.strip().split('\n')
        latest_remote_snap = lines[0]
        remote_props = {l.split('\t')[0]: l.split('\t')[1] for l in lines[1:] if l.startswith("zz:")}
    except: return
    send_flags = "-R" if not args.latest else ""
    send_cmd = ["ssh", remote_host, f"zfs send {send_flags} -v {latest_remote_snap}"]
    recv_cmd = ["zfs", "recv", "-s", "-du", local_pool]
    if run_transfer(send_cmd, recv_cmd) == 0:
        subprocess.run(["zfs", "set", "canmount=on", local_ds]); subprocess.run(["zfs", "set", "readonly=off", local_ds])
        ds = ZzDataset(local_ds)
        for pk, pv in remote_props.items(): ds.set_prop(pk.split(':')[1], pv)
        ds.set_prop("target", args.remote); ds.set_prop("last_sync", int(time.time()))
        print(f"[+] Done.", flush=True)

def run_status(args):
    managed = get_managed_datasets()
    if not managed: print("No managed datasets.", flush=True); return
    print(f"{'DATASET':<20} | {'STATUS':<10} | {'LAST SYNC':<18} | {'NEXT SYNC'}", flush=True)
    print("-" * 75, flush=True)
    for name in managed:
        ds = ZzDataset(name)
        now = int(time.time())
        if ds.last_sync == 0:
            status, last_str, next_run = "INIT", "NEVER", "PENDING"
        else:
            gap = now - ds.last_sync
            freq_sec = parse_duration(ds.props.get("zz:freq", "60m"))
            status = "OK" if gap < freq_sec else "DELAYED"
            last_str = "UNKNOWN" if gap > 86400 * 365 else str(datetime.timedelta(seconds=gap)).split('.')[0] + " ago"
            next_run = "DUE NOW" if gap >= freq_sec else str(datetime.timedelta(seconds=freq_sec-gap)).split('.')[0]
        print(f"{name:<20} | {status:<10} | {last_str:<18} | {next_run}", flush=True)

def run_meta(args):
    ds = ZzDataset(args.dataset)
    if not ds or not ds.props: return
    print(f"\n[ zz Contract: {args.dataset} ]", flush=True)
    print(f"{'DESCRIPTION':<22} | {'KEY':<12} | {'VALUE'}", flush=True)
    print("-" * 65, flush=True)
    fields = [('Remote Target','target','zz:target'), ('Sync Frequency','freq','zz:freq'), 
              ('Local Retention','keep_local','zz:keep_local'), ('Remote Retention','keep_remote','zz:keep_remote'),
              ('Safety Floor (Min)','keep_min','zz:keep_min')]
    for d, k, p in fields:
        val = ds.props.get(p, "-")
        if k in ['freq', 'keep_local', 'keep_remote'] and val != "-": val = human_duration(parse_duration(val))
        print(f"{d:<22} | {k:<12} | {val}", flush=True)

def run_set(args):
    ds = ZzDataset(args.dataset)
    if ds: ds.set_prop(args.prop, args.value); print(f"[*] Updated {args.prop} to {args.value}", flush=True)

def run_abort(args):
    ds = ZzDataset(args.dataset)
    if not ds or ds.target == "-": return
    remote_host, _ = ds.target.split(':')
    subprocess.run(["ssh", remote_host, f"zfs recv -A {args.dataset}"])
    print("[+] Resume token cleared.", flush=True)

def main():
    parser = argparse.ArgumentParser(prog='zz', description='Zeasy: Simplified ZFS Replication', formatter_class=argparse.RawDescriptionHelpFormatter)
    subparsers = parser.add_subparsers(title='Commands', dest='command', metavar='<command>')
    pi = subparsers.add_parser('init', help='Setup replication'); pi.add_argument('dataset'); pi.add_argument('remote')
    pi.add_argument('--freq', default='60m'); pi.add_argument('--keep-local', default='7d'); pi.add_argument('--keep-remote', default='30d'); pi.add_argument('--keep-min', default='10'); pi.set_defaults(func=run_init)
    ps = subparsers.add_parser('sync', help='Run sync'); ps.add_argument('dataset', nargs='?'); ps.add_argument('--force', action='store_true'); ps.set_defaults(func=run_sync)
    subparsers.add_parser('status', help='Show health').set_defaults(func=run_status)
    pm = subparsers.add_parser('meta', help='View config'); pm.add_argument('dataset'); pm.set_defaults(func=run_meta)
    pset = subparsers.add_parser('set', help='Update props'); pset.add_argument('dataset'); pset.add_argument('prop', choices=['target', 'freq', 'keep_local', 'keep_remote', 'keep_min']); pset.add_argument('value'); pset.set_defaults(func=run_set)
    pa = subparsers.add_parser('abort', help='Clear resume tokens'); pa.add_argument('dataset'); pa.set_defaults(func=run_abort)
    pf = subparsers.add_parser('forget', help='Stop tracking'); pf.add_argument('dataset'); pf.set_defaults(func=run_forget)
    pr = subparsers.add_parser('restore', help='Recover'); pr.add_argument('remote'); pr.add_argument('local_dataset'); pr.add_argument('--latest', action='store_true'); pr.set_defaults(func=run_restore)
    args = parser.parse_args(); (args.func(args) if hasattr(args, 'func') else parser.print_help())

if __name__ == "__main__": main()
