#!/bin/bash

# Usage: zfs list -t snap [dataset] | ./zz-delta

prev_ts=0

# Print Header
printf "%-15s | %-22s | %-10s | %-10s\n" "SNAPSHOT_TAG" "TIMESTAMP" "DELTA" "HUMAN"
echo "---------------------------------------------------------------------------"

while read -r line; do
    # Filter for zz_auto snapshots
    if [[ "$line" == *"@zz_auto_"* ]]; then
        # Extract the integer timestamp
        ts=$(echo "$line" | grep -oP '(?<=@zz_auto_)[0-9]+')
        
        # Convert Unix TS to readable date
        # Use 'date -d @ts' for Linux/GNU or 'date -r ts' for BSD/macOS
        readable_date=$(date -d "@$ts" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || date -r "$ts" "+%Y-%m-%d %H:%M:%S")

        if [ "$prev_ts" -eq 0 ]; then
            # First snapshot in the set
            printf "%-15s | %-22s | %-10s | %-10s\n" "$ts" "$readable_date" "---" "Initial"
        else
            # Calculate difference
            delta=$((ts - prev_ts))
            
            # Format human delta
            if [ $delta -ge 60 ]; then
                min=$((delta / 60))
                sec=$((delta % 60))
                human="${min}m ${sec}s"
            else
                human="${delta}s"
            fi
            
            printf "%-15s | %-22s | %-10s | %-10s\n" "$ts" "$readable_date" "${delta}s" "$human"
        fi
        prev_ts=$ts
    fi
done
