#!/bin/bash

# Usage: zfs list -t snap | ./zz-delta

prev_ts=0

echo -e "SNAPSHOT_TAG\t\tDELTA_SEC\tHUMAN_TIME"
echo -e "------------------------------------------------------------"

while read -r line; do
    # Filter for our zz_auto snapshots and extract the timestamp
    if [[ "$line" == *"@zz_auto_"* ]]; then
        # Extract the numbers after @zz_auto_
        ts=$(echo "$line" | grep -oP '(?<=@zz_auto_)[0-9]+')
        
        if [ "$prev_ts" -eq 0 ]; then
            # First snapshot in the list
            echo -e "$ts\t---\t\tInitial"
        else
            # Calculate difference
            delta=$((ts - prev_ts))
            
            # Format human time
            if [ $delta -ge 60 ]; then
                min=$((delta / 60))
                sec=$((delta % 60))
                human="${min}m ${sec}s"
            else
                human="${delta}s"
            fi
            
            echo -e "$ts\t$delta\t\t$human"
        fi
        prev_ts=$ts
    fi
done
